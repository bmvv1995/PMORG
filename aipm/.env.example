# AI-PM — șablonul de configurare. Copiază ca .env lângă pachetul aipm și completează.
# Instalarea de produs (install.sh) generează acest fișier automat, cu token real
# și ingestul oprit (PLAN-INTEGRARE etapa 1).

# --- Serviciu ---
# OBLIGATORIU ne-gol în producție: fără el API-ul rulează neautentificat.
AIPM_AUTH_TOKEN=
AIPM_BIND=127.0.0.1
AIPM_PORT=8090

# --- Baza proprie ---
PG_DSN=postgresql://aipm:aipm@127.0.0.1:5432/aipm

# --- Odoo ---
# fake = fixtures locale (dev/test); xmlrpc = instanța reală
ODOO_ADAPTER=fake
ODOO_RPC_URL=http://127.0.0.1:8069
ODOO_BASE_URL=https://horeca.evrika.team
ODOO_DB=horeca
ODOO_RPC_LOGIN=aipm
ODOO_RPC_PASSWORD=

# --- Ingest ---
# false = memoria e inertă (starea de livrare; conducta se deschide explicit,
# la etapa 5 din PLAN-INTEGRARE). true = bucla de chatter pornește.
INGEST_ENABLED=false

# --- Chitanțe ---
# manual = doar din butonul /review (Faza 1 / pre-go-live, decizia D4)
RECEIPT_MODE=manual

# --- LLM + embeddings ---
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=deepseek-v4-pro
EMBED_API_KEY=
EMBED_BASE_URL=https://api.jina.ai/v1
EMBED_MODEL=jina-embeddings-v3
