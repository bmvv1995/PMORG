    <record id="employee_mihai" model="hr.employee"><field name="name">Mihai Stan</field><field name="company_id" ref="world_company"/><field name="job_title">Gestionar</field><field name="work_contact_id" ref="partner_mihai"/><field name="parent_id" ref="employee_andrei"/></record>
