    <record id="identity_ioana" model="pmorg.identity"><field name="company_id" ref="world_company"/><field name="partner_id" ref="partner_ioana"/></record>
    <record id="employee_elena" model="hr.employee"><field name="name">Elena Marin</field><field name="company_id" ref="world_company"/><field name="job_title">Managing Partner</field><field name="work_contact_id" ref="partner_elena"/></record>
    <record id="employee_dan" model="hr.employee"><field name="name">Dan Petre</field><field name="company_id" ref="world_company"/><field name="job_title">Senior Consultant</field><field name="work_contact_id" ref="partner_dan"/><field name="parent_id" ref="employee_elena"/></record>
    <record id="employee_ioana" model="hr.employee"><field name="name">Ioana Sava</field><field name="company_id" ref="world_company"/><field name="job_title">Consultant</field><field name="work_contact_id" ref="partner_ioana"/><field name="parent_id" ref="employee_dan"/></record>
    <record id="world_project" model="project.project"><field name="name">Livrări clienți — TEST</field><field name="company_id" ref="world_company"/></record>
