<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="world_company" model="res.company"><field name="name">Birou Servicii Test SRL</field></record>
    <record id="partner_elena" model="res.partner"><field name="name">Elena Marin</field><field name="company_id" ref="world_company"/><field name="email">elena.marin@birou-srv.example</field></record>
    <record id="partner_dan" model="res.partner"><field name="name">Dan Petre</field><field name="company_id" ref="world_company"/><field name="email">dan.petre@birou-srv.example</field></record>
    <record id="partner_ioana" model="res.partner"><field name="name">Ioana Sava</field><field name="company_id" ref="world_company"/><field name="email">ioana.sava@birou-srv.example</field></record>
    <record id="user_elena" model="res.users">
        <field name="login">elena.marin@birou-srv.example</field>
        <field name="partner_id" ref="partner_elena"/>
        <field name="company_id" ref="world_company"/>
        <field name="company_ids" eval="[(4, ref('world_company'))]"/>
