<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Profilul ORG-MIN (04-NEXT-SESSION §7, suita v0.3): fără angajați,
         identități canonice pmorg.identity peste res.partner (ADR-014).
         Se încarcă NUMAI în mod demo. Fără identificatori reali (.example). -->

    <record id="pmorg_demo_company" model="res.company">
        <field name="name">Atelier Minimal Test SRL</field>
    </record>

    <record id="pmorg_demo_partner_ana" model="res.partner">
        <field name="name">Ana Dobre</field>
        <field name="company_id" ref="pmorg_demo_company"/>
        <field name="email">ana.dobre@atelier-min.example</field>
    </record>
    <record id="pmorg_demo_partner_paul" model="res.partner">
        <field name="name">Paul Rusu</field>
        <field name="company_id" ref="pmorg_demo_company"/>
        <field name="email">paul.rusu@atelier-min.example</field>
    </record>
    <record id="pmorg_demo_partner_victor" model="res.partner">
        <field name="name">Victor Neagu</field>
        <field name="company_id" ref="pmorg_demo_company"/>
        <field name="email">victor.neagu@atelier-min.example</field>
    </record>
    <record id="pmorg_demo_partner_agent" model="res.partner">
        <field name="name">PMORG Test Agent</field>
        <field name="company_id" ref="pmorg_demo_company"/>
    </record>

    <!-- Ana acționează în Odoo (owner) => are user; ceilalți nu au nevoie. -->
    <record id="pmorg_demo_user_ana" model="res.users">
        <field name="login">ana.dobre@atelier-min.example</field>
        <field name="partner_id" ref="pmorg_demo_partner_ana"/>
        <field name="company_id" ref="pmorg_demo_company"/>
        <field name="company_ids" eval="[(4, ref('pmorg_demo_company'))]"/>
    </record>

    <record id="pmorg_demo_identity_ana" model="pmorg.identity">
        <field name="company_id" ref="pmorg_demo_company"/>
        <field name="partner_id" ref="pmorg_demo_partner_ana"/>
        <field name="user_id" ref="pmorg_demo_user_ana"/>
        <field name="identity_kind">human</field>
    </record>
    <record id="pmorg_demo_identity_paul" model="pmorg.identity">
        <field name="company_id" ref="pmorg_demo_company"/>
        <field name="partner_id" ref="pmorg_demo_partner_paul"/>
        <field name="identity_kind">human</field>
    </record>
    <record id="pmorg_demo_identity_victor" model="pmorg.identity">
        <field name="company_id" ref="pmorg_demo_company"/>
        <field name="partner_id" ref="pmorg_demo_partner_victor"/>
        <field name="identity_kind">human</field>
    </record>
    <record id="pmorg_demo_identity_agent" model="pmorg.identity">
        <field name="company_id" ref="pmorg_demo_company"/>
        <field name="partner_id" ref="pmorg_demo_partner_agent"/>
        <field name="identity_kind">agent</field>
    </record>

    <record id="pmorg_demo_project" model="project.project">
        <field name="name">Coordonare internă — TEST</field>
        <field name="company_id" ref="pmorg_demo_company"/>
    </record>

    <record id="pmorg_demo_initiative" model="pmorg.initiative">
        <field name="name">MIN-001 — clarifică criteriul de acceptare</field>
        <field name="objective">Stabilirea criteriului de acceptare lipsă și finalizarea livrabilului</field>
        <field name="state">draft</field>
        <field name="company_id" ref="pmorg_demo_company"/>
        <field name="owner_identity_id" ref="pmorg_demo_identity_ana"/>
        <field name="project_id" ref="pmorg_demo_project"/>
    </record>

    <record id="pmorg_demo_criterion" model="pmorg.success.criterion">
        <field name="name">Criteriu confirmat și livrabil finalizat cu dovadă</field>
        <field name="initiative_id" ref="pmorg_demo_initiative"/>
    </record>

    <record id="pmorg_demo_task_clarify" model="project.task">
        <field name="name">Obține criteriul de acceptare lipsă</field>
        <field name="project_id" ref="pmorg_demo_project"/>
        <field name="company_id" ref="pmorg_demo_company"/>
        <field name="pmorg_initiative_id" ref="pmorg_demo_initiative"/>
        <field name="pmorg_task_type">clarification</field>
        <field name="execution_mode">agent</field>
        <field name="expected_outcome">Criteriu de acceptare explicit, confirmat de validator</field>
        <field name="participant_ids" eval="[(4, ref('pmorg_demo_identity_victor'))]"/>
    </record>

    <record id="pmorg_demo_anchor_subject" model="pmorg.anchor">
        <field name="task_id" ref="pmorg_demo_task_clarify"/>
        <field name="company_id" ref="pmorg_demo_company"/>
        <field name="model_name">pmorg.initiative</field>
        <field name="res_id" eval="ref('pmorg_demo_initiative')"/>
        <field name="role">subject</field>
    </record>

    <record id="pmorg_demo_task_action" model="project.task">
        <field name="name">Finalizează livrabilul conform criteriului confirmat</field>
        <field name="project_id" ref="pmorg_demo_project"/>
        <field name="company_id" ref="pmorg_demo_company"/>
        <field name="pmorg_initiative_id" ref="pmorg_demo_initiative"/>
        <field name="pmorg_task_type">execution</field>
        <field name="execution_mode">human</field>
    </record>
</odoo>
