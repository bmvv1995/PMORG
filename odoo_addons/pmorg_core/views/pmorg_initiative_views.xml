<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- FORM -->
    <record id="pmorg_initiative_view_form" model="ir.ui.view">
        <field name="name">pmorg.initiative.form</field>
        <field name="model">pmorg.initiative</field>
        <field name="arch" type="xml">
            <form string="Initiative">
                <header>
                    <button name="action_start_clarification" string="Clarify" type="object" invisible="state != 'draft'"/>
                    <button name="action_start_planning" string="Plan" type="object" invisible="state != 'clarifying'"/>
                    <button name="action_request_confirmation" string="Ask Confirmation" type="object" invisible="state != 'planned'"/>
                    <button name="action_activate" string="Activate" type="object" invisible="state != 'awaiting_confirmation'"/>
                    <button name="action_start_verification" string="Verify" type="object" invisible="state != 'active'"/>
                    <button name="action_close" string="Close" type="object" invisible="state != 'verifying'"/>
                    <button name="action_cancel" string="Cancel" type="object" invisible="state in ('closed', 'cancelled')"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,clarifying,planned,awaiting_confirmation,active,verifying,closed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <field name="reference" readonly="1"/>
                        <h1><field name="name" placeholder="Numele inițiativei..."/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="owner_id"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="priority" widget="priority"/>
                            <field name="project_id"/>
                        </group>
                        <group>
                            <field name="task_count"/>
                            <field name="followup_count"/>
                            <field name="escalation_level"/>
                            <field name="verification_status"/>
                            <field name="next_check_at"/>
                        </group>
                    </group>
                    <group invisible="state != 'cancelled'">
                        <field name="cancel_reason"/>
                    </group>
                    <notebook>
                        <page string="Obiectiv" name="objective">
                            <field name="objective"/>
                            <field name="description"/>
                        </page>
                        <page string="Criterii de succes" name="criteria">
                            <field name="success_criterion_ids" nolabel="1">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="verified"/>
                                    <field name="verified_by_id"/>
                                    <field name="verified_at"/>
                                    <field name="evidence_note"/>
                                </list>
                            </field>
                        </page>
                        <page string="Taskuri" name="tasks">
                            <field name="task_ids"/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- LIST - with search, filters, grouping -->
    <record id="pmorg_initiative_view_list" model="ir.ui.view">
        <field name="name">pmorg.initiative.list</field>
        <field name="model">pmorg.initiative</field>
        <field name="arch" type="xml">
            <list string="Initiatives" decoration-success="state in ('verifying', 'closed')" decoration-warning="state == 'active'" decoration-danger="state == 'cancelled'" decoration-info="state == 'clarifying'">
                <field name="name"/>
                <field name="owner_id" widget="many2one_avatar_user"/>
                <field name="priority" widget="priority"/>
                <field name="state" widget="badge" decoration-success="state in ('verifying', 'closed')" decoration-warning="state == 'active'" decoration-info="state == 'clarifying'" decoration-danger="state == 'cancelled'"/>
                <field name="task_count"/>
                <field name="objective"/>
                <field name="create_date"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <!-- KANBAN -->
    <record id="pmorg_initiative_view_kanban" model="ir.ui.view">
        <field name="name">pmorg.initiative.kanban</field>
        <field name="model">pmorg.initiative</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile">
                <field name="name"/>
                <field name="state"/>
                <field name="priority"/>
                <field name="owner_id"/>
                <field name="task_count"/>
                <templates>
                    <t t-name="card">
                        <div class="row mb4">
                            <div class="col-6">
                                <strong><field name="name"/></strong>
                            </div>
                            <div class="col-6 text-end">
                                <field name="priority" widget="priority"/>
                            </div>
                        </div>
                        <div>
                            <span>State: <field name="state"/></span>
                        </div>
                        <div>
                            <span>Tasks: <field name="task_count"/></span>
                        </div>
                        <div>
                            <field name="owner_id" widget="many2one_avatar_user"/>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- SEARCH -->
    <record id="pmorg_initiative_view_search" model="ir.ui.view">
        <field name="name">pmorg.initiative.search</field>
        <field name="model">pmorg.initiative</field>
        <field name="arch" type="xml">
            <search string="Search Initiatives">
                <field name="name"/>
                <field name="objective"/>
                <field name="owner_id"/>
                <separator/>
                <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Active" name="active" domain="[('state', '=', 'active')]"/>
                <filter string="Planned" name="planned" domain="[('state', '=', 'planned')]"/>
                <filter string="Verifying" name="verifying" domain="[('state', '=', 'verifying')]"/>
                <filter string="Closed" name="closed" domain="[('state', '=', 'closed')]"/>
                <separator/>
                <filter string="High Priority" name="high_priority" domain="[('priority', 'in', ('2', '3'))]"/>
                <separator/>
                <filter string="State" name="group_state" context="{'group_by': 'state'}"/>
                <filter string="Priority" name="group_priority" context="{'group_by': 'priority'}"/>
                <filter string="Owner" name="group_owner" context="{'group_by': 'owner_id'}"/>
            </search>
        </field>
    </record>

    <!-- ACTION -->
    <record id="pmorg_initiative_action" model="ir.actions.act_window">
        <field name="name">Initiatives</field>
        <field name="res_model">pmorg.initiative</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="context">{"search_default_active": 0}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first PMORG initiative
            </p>
        </field>
    </record>
</odoo>
