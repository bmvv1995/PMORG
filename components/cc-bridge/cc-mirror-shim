def admin_page_html(token):
    items = []
    for r in reversed(admin_load()):
        st = r.get("status", "pending")
        body = (f"<div class='req {st}'><b>#{r['id']} · {r['action']}</b>"
                f" · status: <b>{st}</b>"
                f"<pre>params: {json.dumps(r.get('params'), ensure_ascii=False)}\n"
                f"motivație (PM): {r.get('rationale','')}</pre>")
        if st == "pending":
            body += (f"<form method='post' action='/admin/decide'>"
                     f"<input type='hidden' name='token' value='{token}'>"
                     f"<input type='hidden' name='id' value='{r['id']}'>"
                     f"<input type='text' name='confirm' "
                     f"placeholder='scrie: {r['action']}' autocomplete='off'> "
                     f"<button name='decision' value='approve'>✅ Aprobă</button> "
                     f"<button name='decision' value='deny'>❌ Respinge</button>"
                     f"</form>")
        elif r.get("result"):
            body += f"<pre>rezultat: {r['result'][:400]}</pre>"
        items.append(body + "</div>")
    return ADMIN_PAGE.format(items="".join(items) or "<p>Nicio cerere.</p>")


class AdminHandler(BaseHTTPRequestHandler):
    protocol_version = "HTTP/1.1"

    def _html(self, text, status=200):
        body = text.encode()
        self.send_response(status)
        self.send_header("Content-Type", "text/html; charset=utf-8")
        self.send_header("Content-Length", str(len(body)))
        self.end_headers()
        self.wfile.write(body)

    def _authorized(self, token):
        return token and hmac.compare_digest(token, admin_token())

    def do_GET(self):
        parsed = urllib.parse.urlparse(self.path)
        q = urllib.parse.parse_qs(parsed.query)
        token = (q.get("token") or [""])[0]
        if parsed.path.rstrip("/") != "/admin" or not self._authorized(token):
            self._html("<h3>404</h3>", 404)
            return
        self._html(admin_page_html(token))

    def do_POST(self):
        if self.path != "/admin/decide":
            self._html("<h3>404</h3>", 404)
            return
        length = int(self.headers.get("Content-Length", 0))
        form = urllib.parse.parse_qs(self.rfile.read(length).decode())
        get = lambda k: (form.get(k) or [""])[0]
        token = get("token")
        if not self._authorized(token):
            self._html("<h3>404</h3>", 404)
            return
        rid, decision, confirm = get("id"), get("decision"), get("confirm")
        reqs = {str(r["id"]): r for r in admin_load()}
        r = reqs.get(rid)
        back = (f"<p><a href='/admin?token={token}'>← înapoi la listă</a></p>")
        if not r or r.get("status") != "pending":
            self._html(f"<p class='err'>Cererea #{rid} nu e în așteptare.</p>{back}")
            return
        if decision == "deny":
            r["status"] = "denied"
            admin_save(r)
            self._html(f"<p>Cererea #{rid} respinsă.</p>{back}")
            return
        if confirm.strip() != r["action"]:
            self._html(f"<p class='err'>Confirmare greșită: scrie exact "
                       f"«{r['action']}» pentru a aproba.</p>{back}")
            return
        ok, out = admin_execute(r)
        r["status"] = "executed" if ok else "failed"
        r["result"] = out
        admin_save(r)
        cls = "ok" if ok else "err"
        self._html(f"<p class='{cls}'>Cererea #{rid}: "
                   f"{'executată' if ok else 'EȘUATĂ'}.</p><pre>{out}</pre>{back}")

    def log_message(self, fmt, *args):
        print(f"[admin] {fmt % args}", flush=True)


class Handler(BaseHTTPRequestHandler):
    protocol_version = "HTTP/1.1"

    def _json(self, obj, status=200):
        body = json.dumps(obj, ensure_ascii=False).encode()
        self.send_response(status)
        self.send_header("Content-Type", "application/json")
        self.send_header("Content-Length", str(len(body)))
        self.end_headers()
        self.wfile.write(body)

    def do_GET(self):
        if self.path.rstrip("/").endswith("/models"):
            _, sessions = 0, []
            r = subprocess.run([CC_BRIDGE, "list"], capture_output=True, text=True)
            for line in r.stdout.splitlines():
                try:
                    sessions.append(json.loads(line)["name"])
                except (json.JSONDecodeError, KeyError):
                    pass
            self._json({"object": "list", "data": [
                {"id": s, "object": "model", "owned_by": "cc-bridge"}
                for s in sessions]})
        else:
            self._json({"error": "unknown path"}, 404)

    def do_POST(self):
        if "chat/completions" not in self.path:
            self._json({"error": "unknown path"}, 404)
            return
        length = int(self.headers.get("Content-Length", 0))
        req = json.loads(self.rfile.read(length))
        tools = req.get("tools") or []
        print(f"[shim] keys={sorted(req.keys())} n_messages={len(req.get('messages', []))} "
              f"n_tools={len(tools)} tool_names={[t.get('function', {}).get('name') for t in tools[:10]]}",
              flush=True)
        session = (req.get("model") or "demo").split("/")[-1]
        text = last_user_text(req.get("messages", []))

        try:
            # serializare per sesiune: două canale simultane (ex. Telegram +
            # dashboard) nu au voie să scrie interleaved în același tmux.
            # Așteptăm la coadă cel mult 90s (sub timeout-ul providerului);
            # peste — răspuns onest de ocupat, nu eroare mută de timeout.
            lock = session_lock(session)
            if lock.acquire(timeout=90):
                try:
                    reply = run_turn(session, text) if text else "(mesaj gol)"
                finally:
                    lock.release()
            else:
                reply = ("⏳ Procesez altă cerere chiar acum și nu am terminat "
                         "în timp util. Retrimite mesajul în ~1 minut.")
        except subprocess.TimeoutExpired:
            reply = "Bridge-ul nu a răspuns în timp util (subprocess timeout)."

        completion_id = f"chatcmpl-{uuid.uuid4().hex[:12]}"
        created = int(time.time())

        if req.get("stream"):
            self.send_response(200)
            self.send_header("Content-Type", "text/event-stream")
            self.send_header("Cache-Control", "no-cache")
            self.send_header("Connection", "close")
            self.end_headers()
            chunk = {"id": completion_id, "object": "chat.completion.chunk",
                     "created": created, "model": session,
                     "choices": [{"index": 0,
                                  "delta": {"role": "assistant", "content": reply},
                                  "finish_reason": None}]}
            self.wfile.write(f"data: {json.dumps(chunk, ensure_ascii=False)}\n\n".encode())
            done = dict(chunk)
            done["choices"] = [{"index": 0, "delta": {}, "finish_reason": "stop"}]
            self.wfile.write(f"data: {json.dumps(done)}\n\ndata: [DONE]\n\n".encode())
            return

        self._json({
            "id": completion_id, "object": "chat.completion",
            "created": created, "model": session,
            "choices": [{"index": 0, "finish_reason": "stop",
                         "message": {"role": "assistant", "content": reply}}],
            "usage": {"prompt_tokens": 0, "completion_tokens": 0,
                      "total_tokens": 0},
        })

    def log_message(self, fmt, *args):
        print(f"[shim] {fmt % args}", flush=True)


