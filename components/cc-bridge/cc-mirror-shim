#!/usr/bin/env python3
"""cc-mirror-shim — provider OpenAI-compatible care rutează către Claude Code.

Hermes crede că vorbește cu un LLM; de fapt "modelul" e numele unei sesiuni
cc-bridge, iar "inferența" e `cc-bridge send --wait`. Sursa de adevăr a
conversației rămâne transcriptul CC; Hermes primește răspunsul verbatim și
îl persistă/relatează prin toată infrastructura lui (gateway, FTS, sesiuni).

Rutare specială: dacă mesajul utilizatorului e "approve"/"deny" și sesiunea
CC așteaptă aprobare, se traduce în cc-bridge approve/deny, nu în send.
"""
import json
import os
import hmac
import secrets
import subprocess
import threading
import time
import urllib.parse
import uuid
from http.server import BaseHTTPRequestHandler, ThreadingHTTPServer

PORT = 9127
CC_BRIDGE = "/home/vscode/.local/bin/cc-bridge"
SEND_TIMEOUT = 240

# Administrare asincronă (HIL): PM-ul depune cereri (admin_request în MCP),
# ownerul decide RITUALIC pe pagina de aprobări (port separat, token, numele
# acțiunii scris de mână). Executorul e AICI — determinist, nu în agent.
ADMIN_PORT = 9128
ADMIN_QUEUE = "/home/vscode/.cc-bridge/admin-queue"
ADMIN_TOKEN_FILE = "/home/vscode/.cc-bridge/admin.token"
HERMES_HOME = "/home/vscode/.hermes"
HERMES_BIN = "/home/vscode/.local/bin/hermes"
PM_BIN = "/home/vscode/.local/bin/pm"
ONTOLOGY_DIR = "/home/vscode/hermes-ontology"

# serializare: un singur mesaj odată per sesiune CC (tmux nu suportă
# interleaving de paste-buffer; dispecerul lucrează oricum secvențial)
_session_locks = {}
_locks_guard = threading.Lock()


def session_lock(session):
    with _locks_guard:
        return _session_locks.setdefault(session, threading.Lock())


def admin_token():
    if not os.path.exists(ADMIN_TOKEN_FILE):
        os.makedirs(os.path.dirname(ADMIN_TOKEN_FILE), exist_ok=True)
        with open(ADMIN_TOKEN_FILE, "w") as f:
            f.write(secrets.token_hex(16))
        os.chmod(ADMIN_TOKEN_FILE, 0o600)
    return open(ADMIN_TOKEN_FILE).read().strip()
# Autostart: o sesiune necunoscută e pornită automat, ca "selectează profilul
# → gata" să nu ceară cc-bridge start manual. Configurare per sesiune:
# implicit = plan mode (mirror de planificare); sesiunile numite explicit pot
# avea alt mod/workdir (ex. pm = dispecerul cu unelte MCP scopate în workdir).
AUTOSTART = True
AUTOSTART_WORKDIR_BASE = "/home/vscode/cc-sessions"  # <base>/<session>
SESSION_DEFAULTS = {"model": "sonnet", "permission_mode": "plan"}
SESSION_PROFILES = {
    # PM-on-CC: fără plan mode (are nevoie de unelte); mâinile lui sunt DOAR
    # serverul MCP hermes-ops din workdir (built-ins interzise prin settings).
    "pm": {"model": "sonnet", "permission_mode": "default"},
}


def session_profile(session):
    cfg = dict(SESSION_DEFAULTS)
    cfg.update(SESSION_PROFILES.get(session, {}))
    cfg.setdefault("workdir", os.path.join(AUTOSTART_WORKDIR_BASE, session))
    return cfg


def bridge(*args):
    r = subprocess.run([CC_BRIDGE, *args], capture_output=True, text=True,
                       timeout=SEND_TIMEOUT + 30)
    if r.returncode == 1:  # 2 = AWAITING_APPROVAL (normal), doar 1 e eroare
        print(f"[bridge] {' '.join(args)} rc={r.returncode} "
              f"out={r.stdout.strip()[:150]!r} err={r.stderr.strip()[:300]!r}",
              flush=True)
    try:
        return r.returncode, json.loads(r.stdout)
    except json.JSONDecodeError:
        # ex: `start` scrie "pornit: ..." (non-JSON) — nu e eroare fatală
        return r.returncode, {"note": (r.stdout + r.stderr).strip()[:200]}


def last_user_text(messages):
    for m in reversed(messages):
        if m.get("role") != "user":
            continue
        c = m.get("content")
        if isinstance(c, str):
            return c
        if isinstance(c, list):
            return "\n".join(b.get("text", "") for b in c
                             if isinstance(b, dict) and b.get("type") == "text")
    return ""


def ensure_session(session):
    """Pornește sesiunea CC dacă nu rulează (autostart, config per sesiune)."""
    _, st = bridge("status", session)
    if st.get("state") in ("STOPPED", "UNKNOWN") and AUTOSTART:
        cfg = session_profile(session)
        bridge("start", session, "--workdir", cfg["workdir"],
               "--model", cfg["model"],
               "--permission-mode", cfg["permission_mode"])
        time.sleep(2)
        return bridge("status", session)[1]
    return st


def run_turn(session, text):
    """Un mesaj de utilizator -> un răspuns, prin cc-bridge."""
    stripped = text.strip().lower()
    st = ensure_session(session)
    state = st.get("state", "UNKNOWN")

    if state == "AWAITING_APPROVAL":
        # întrebare AskUserQuestion activă: un număr = selectează opțiunea
        if st.get("question"):
            nums = [int(x) for x in stripped.replace(",", " ").split()
                    if x.isdigit()]
            if nums:
                code, res = bridge("answer", session, str(nums[0]), "--wait",
                                   "--timeout", str(SEND_TIMEOUT))
                return outcome_text(code, res)
            if stripped in ("deny", "/deny", "cancel", "esc"):
                bridge("deny", session)
                return "Am anulat întrebarea (Esc trimis către CC)."
            # text liber peste o întrebare: Esc apoi trimite ca răspuns nou
            bridge("deny", session)
            time.sleep(1.5)
            code, res = bridge("send", session, text, "--force", "--wait",
                               "--timeout", str(SEND_TIMEOUT))
            return outcome_text(code, res)
        if stripped in ("approve", "/approve", "da", "yes"):
            code, res = bridge("approve", session, "--wait",
                               "--timeout", str(SEND_TIMEOUT))
            return outcome_text(code, res)
        if stripped in ("deny", "/deny", "nu", "no"):
            bridge("deny", session)
            return "Am respins cererea de permisiune (Esc trimis către CC)."
        if st.get("plan"):
            # feedback pe plan: rămâi în planning (Esc) și trimite feedbackul
            bridge("deny", session)
            time.sleep(1.5)
            code, res = bridge("send", session, text, "--force", "--wait",
                               "--timeout", str(SEND_TIMEOUT))
            return outcome_text(code, res)
        return ("⏳ CC așteaptă aprobare: "
                f"{st.get('last_event', {}).get('message', 'permission prompt')}\n"
                "Răspunde cu «approve» sau «deny» înainte de a trimite altceva.")

    if state == "STOPPED":
        return (f"Sesiunea CC «{session}» nu rulează. "
                f"Pornește-o cu: cc-bridge start {session} --workdir <dir>")

    code, res = bridge("send", session, text, "--wait",
                       "--timeout", str(SEND_TIMEOUT))
    return outcome_text(code, res)


def render_question(q):
    lines = []
    if q.get("header"):
        lines.append(f"❓ {q['header']}")
    lines.append(q.get("text") or "CC îți pune o întrebare:")
    for i, o in enumerate(q.get("options") or [], 1):
        desc = f" — {o['description']}" if o.get("description") else ""
        lines.append(f"  {i}. {o.get('label','')}{desc}")
    hint = ("Răspunde cu numerele opțiunilor (ex: 1,3)."
            if q.get("multi") else
            "Răspunde cu numărul opțiunii (ex: 1), sau scrie liber pentru alt răspuns.")
    lines.append("\n" + hint)
    return "\n".join(lines)


def outcome_text(code, res):
    if res.get("outcome") == "IDLE":
        return res.get("reply") or "(CC a terminat fără mesaj final)"
    if res.get("outcome") == "AWAITING_APPROVAL":
        if res.get("plan"):
            return (f"{res['plan']}\n\n---\n"
                    "📋 Plan de la CC. «approve» = trece la execuție · "
                    "«deny» = rămâne în plan mode (poți cere modificări).")
        if res.get("question"):
            return render_question(res["question"])
        return ("⏳ CC cere permisiune "
                f"({res.get('pending_tool', '?')}): "
                f"{res.get('permission_request', 'permission prompt')}\n"
                "Răspunde cu «approve» sau «deny».")
    if res.get("outcome") == "TIMEOUT":
        return ("CC încă lucrează (timeout de așteptare atins). "
                "Trimite orice mesaj ca să verific din nou starea.")
    return f"Eroare bridge: {json.dumps(res, ensure_ascii=False)[:300]}"


# ---------------------------------------------------------- admin executor

def admin_load():
    reqs = []
    if os.path.isdir(ADMIN_QUEUE):
        for fn in sorted(os.listdir(ADMIN_QUEUE)):
            if fn.endswith(".json"):
                try:
                    reqs.append(json.load(open(os.path.join(ADMIN_QUEUE, fn))))
                except (json.JSONDecodeError, OSError):
                    pass
    return reqs


def admin_save(req):
    os.makedirs(ADMIN_QUEUE, exist_ok=True)
    with open(os.path.join(ADMIN_QUEUE, f"req-{req['id']:04d}.json"), "w") as f:
        json.dump(req, f, ensure_ascii=False, indent=1)


def _run(cmd, timeout=120):
    r = subprocess.run(cmd, capture_output=True, text=True, timeout=timeout)
    out = (r.stdout + "\n" + r.stderr).strip()
    return r.returncode == 0, out[-500:]


def _git_commit(msg):
    _run(["git", "-C", HERMES_HOME, "add", "-A"])
    return _run(["git", "-C", HERMES_HOME, "-c", "user.name=admin-executor",
                 "-c", "user.email=bmvv.gps@gmail.com", "commit", "-m", msg])


def admin_execute(req):
    """Execută o cerere admin aprobată. Determinist; commit git atomic."""
    action, p = req["action"], req.get("params") or {}
    if action == "profile_create":
        cmd = [HERMES_BIN, "profile", "create", p["name"]]
        if p.get("clone_from"):
            cmd += ["--clone-from", p["clone_from"]]
        if p.get("description"):
            cmd += ["--description", p["description"]]
        ok, out = _run(cmd)
    elif action == "soul_write":
        path = os.path.join(HERMES_HOME, "profiles", p["profile"], "SOUL.md")
        if not os.path.isdir(os.path.dirname(path)):
            return False, f"profilul {p.get('profile')} nu există"
        with open(path, "w") as f:
            f.write(p["content"])
        ok, out = True, f"SOUL.md scris ({len(p['content'])} caractere)"
    elif action == "ontology_install":
        dest = os.path.join(HERMES_HOME, "profiles", p["profile"],
                            "skills", "organization", "hermes-ops")
        if not os.path.isdir(os.path.join(HERMES_HOME, "profiles", p["profile"])):
            return False, f"profilul {p.get('profile')} nu există"
        ok, out = _run(["bash", "-c",
                        f"mkdir -p '{dest}' && cp -r '{ONTOLOGY_DIR}/.' '{dest}/' "
                        f"&& rm -rf '{dest}/.git'"])
    elif action == "allowlist_add":
        env_path = os.path.join(HERMES_HOME, "profiles", "pm", ".env")
        lines, done = [], False
        for line in open(env_path).read().splitlines():
            if line.startswith("TELEGRAM_ALLOWED_USERS="):
                ids = [x for x in line.split("=", 1)[1].split(",") if x.strip()]
                if str(p["telegram_id"]) not in ids:
                    ids.append(str(p["telegram_id"]))
                line = "TELEGRAM_ALLOWED_USERS=" + ",".join(ids)
                done = True
            lines.append(line)
        if not done:
            lines.append(f"TELEGRAM_ALLOWED_USERS={p['telegram_id']}")
        with open(env_path, "w") as f:
            f.write("\n".join(lines) + "\n")
        ok, out = _run(["systemctl", "--user", "restart", "hermes-gateway-pm"])
        out = f"allowlist actualizat; gateway repornit. {out}"
    elif action == "gateway_restart":
        ok, out = _run(["systemctl", "--user", "restart", "hermes-gateway-pm"])
    else:
        return False, f"acțiune necunoscută: {action}"
    if ok:
        _git_commit(f"admin: {action} — cerere #{req['id']}: "
                    f"{req.get('rationale', '')[:80]}")
    return ok, out


